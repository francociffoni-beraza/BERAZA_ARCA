{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(format:*)",
      "Bash(del /s:*)"
    ]
  }
}